                },
                "url": {
                    "raw": "http://127.0.0.1:5000/predict",
                    "protocol": "http",
                    "host": ["127", "0", "0", "1"],
                    "port": "5000",
                    "path": ["predict"]
                }
            }
        },
        {
            "name": "Missing Data Prediction",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
