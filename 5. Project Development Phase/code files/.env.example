# Rising Waters Environment Variables
# Rename this file to .env and configure the variables below

# Flask application secret key used for sessions and secure cookies
# Replace with a strong random string in production
FLASK_SECRET_KEY=dev-secret-key-super-secure

# PostgreSQL connection string (required — app will not start without this)
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
SQLALCHEMY_DATABASE_URI=postgresql://user:password@localhost:5432/rising_waters
